---
import { ClientRouter } from 'astro:transitions';
import "../styles/global.css";

const { title, description, showFooter = true } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title || "4x10.dev | AI-powered platform for show programming"}</title>
    <meta name="description" content={description || "4x10.dev is a team building an AI-powered platform for show programming. Explore our Show Engine, Signal Processing Engine, and Pan/Tilt Suite."}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <ClientRouter />
</head>
<body>
    <header>
        <nav class="container">
            <div class="logo-fixed">
                <a href="/website/"><img src="/website/assets/logo.png" alt="4x10.dev Logo"></a>
            </div>
            <ul class="nav-links">
                <li><a href="/website/show-engine">Show Engine</a></li>
                <li><a href="/website/signal-processing">Signal Processing Engine</a></li>
                <li><a href="/website/pan-tilt">Pan/Tilt Suite</a></li>
                <li><a href="/website/shop">Shop</a></li>
                <li><a href="/website/team">Team</a></li>
                <li><a href="/website/contacts">Contacts</a></li>
            </ul>
            <button class="mobile-menu-btn" aria-label="Toggle Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </nav>
    </header>

    <slot />

    {showFooter && (
    <footer>
        <div class="container footer-links">
            <div class="footer-row">
                <a href="/website/contacts">Contact Us</a>
                <a href="/website/legal-info">Legal Info</a>
                <a href="/website/privacy-policy">Privacy Policy</a>
            </div>
            <div class="footer-row">
                <a href="/website/cookie-settings">Cookie Settings</a>
                <a href="/website/imprint">Imprint</a>
            </div>
        </div>
    </footer>
    )}

    <script src="/website/script.js" is:inline></script>
</body>
</html>
