---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
<section id="team" class="team-section">
            <div class="container">
                <div class="team-grid">
                    <div class="team-member reveal">
                        <img src="/assets/team/pavel_final.webp"
                            alt="Pavel Zmunchila" loading="lazy">
                        <h3>Pavel Zmunchila</h3>
                        <p class="role">CEO</p>
                        <p class="company">SETUP</p>
                        <p class="bio">15+ years expert in show system architecture with deep insight into creative
                            needs, product-market fit, and real-world production.</p>
                    </div>
                    <div class="team-member reveal">
                        <img src="/assets/team/alexander.png"
                            alt="Alexander Letsius" loading="lazy">
                        <h3>Alexander Letsius</h3>
                        <p class="role">CPO</p>
                        <p class="company">404.Zero</p>
                        <p class="bio">Creative developer specializing in architecture, UI/UX, networks, and AI. 15+
                            years building audiovisual installations across diverse technical environments.</p>
                    </div>
                    <div class="team-member reveal">
                        <img src="/assets/team/anton.png"
                            alt="Anton Kochnev" loading="lazy">
                        <h3>Anton Kochnev</h3>
                        <p class="role">CTO</p>
                        <p class="company">SETUP</p>
                        <p class="bio">Tech lead with 10+ years hands-on expertise in gpu servers, audio & lighting
                            systems, AI, and network protocols. Specializes in delivering complex shows.</p>
                    </div>
                    <div class="team-member reveal">
                        <img src="/assets/team/alina.png"
                            alt="Alina Gardamshina" loading="lazy">
                        <h3>Alina Gardamshina</h3>
                        <p class="role">COO</p>
                        <p class="company">SETUP</p>
                        <p class="bio">Operations & Product Lead with 10+ years of experience in multimedia and IT,
                            turning complex ideas into clear, executable workflows.</p>
                    </div>
                    <div class="team-member reveal">
                        <img src="/assets/team/kristina.png"
                            alt="Kristina Karpysheva" loading="lazy">
                        <h3>Kristina Karpysheva</h3>
                        <p class="role">CMO</p>
                        <p class="company">404.Zero</p>
                        <p class="bio">Creative strategist with 12+ years in digital storytelling and generative
                            content. Focused on brand development and audiovisual projects across art and music.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>