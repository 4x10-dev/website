---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
<section id="show-engine" class="product-section">
            <div class="container">
                <div class="product-grid">
                    <div class="product-info reveal">
                        <h2>Show Engine</h2>
                        <h3>AI-Driven Timeline Builder</h3>
                        <p class="description">A next-generation AI-powered timeline and synchronization core for live
                            performance, it delivers frame-level precision across media channels and serves as the
                            backbone of modern show control.</p>
                        <p class="description">Beyond basic beat detection, Show Engine uses a multi-stage signal
                            processing pipeline to generate discrete triggers and continuous envelopes, creating a
                            detailed timeline for lighting, video, kinetic elements, and more.</p>
                        <ul class="feature-list">
                            <li>Real-time data over OSC, MIDI, DMX</li>
                            <li>Keyframe and envelope export for Unreal Engine, After Effects, C4D, or custom pipelines
                            </li>
                            <li>Built-in video playback and real-time visual processing for precise AV sync from one
                                timeline</li>
                        </ul>
                    </div>
                    <div class="product-media reveal">
                        <div class="gif-grid">
                            <img src="/website/assets/gifs/show-engine/demo-1.gif"
                                alt="Show Engine Demo 1" loading="lazy">
                            <img src="/website/assets/gifs/show-engine/demo-2.gif"
                                alt="Show Engine Demo 2" loading="lazy">
                            <img src="/website/assets/gifs/show-engine/demo-3.gif"
                                alt="Show Engine Demo 3" loading="lazy">
                            <img src="/website/assets/gifs/show-engine/demo-4.gif"
                                alt="Show Engine Demo 4" loading="lazy">
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>