---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cookie Settings | 4x10.dev">
    <main class="legal-section">
        <div class="container">
            <div class="legal-content reveal">
                <h1>Cookie Settings</h1>
                
                <p>This website uses essential cookies to ensure basic functionality and to improve your browsing experience. You can customize your preferences below.</p>

                <h2>Essential Cookies</h2>
                <p>These cookies are necessary for the website to function and cannot be switched off. They are typically set in response to actions made by you, such as setting your privacy preferences or filling in forms.</p>

                <h2>Performance & Analytics</h2>
                <p>We use limited analytical tools to understand how visitors interact with our website. This data is fully anonymized and used only for internal performance improvements.</p>

                <div class="cookie-btn-group">
                    <button class="cookie-btn primary">Accept All Cookies</button>
                    <button class="cookie-btn">Necessary Only</button>
                    <button class="cookie-btn">Save Preferences</button>
                </div>

                <p style="margin-top: 2rem; font-size: 0.8rem; opacity: 0.7; text-align: center;">By clicking "Accept All", you consent to our use of all cookies as described in our Privacy Policy.</p>
            </div>
        </div>
    </main>
</Layout>
