---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
<section id="pantiltsuite" class="product-section">
            <div class="container">
                <div class="product-grid">
                    <div class="product-info reveal">
                        <h2>Pan/Tilt Suite</h2>
                        <h3>Revolutionizing Moving Head Programming</h3>
                        <p class="description">The Pan/Tilt Suite transforms moving-head programming by eliminating
                            manual positional control. Its parametric tracking engine generates dynamic 3D motion
                            patterns in seconds, giving each fixture a unique yet coordinated trajectory with minimal
                            effort.</p>
                        <ul class="feature-list">
                            <li>3D calibration & spatial positioning</li>
                            <li>AI-assisted programming & parametric motion</li>
                            <li>Fixture management, layout generation & MVR</li>
                            <li>Cueing, presets & state recall</li>
                            <li>Real-time visualization, GPU optimization & connectivity</li>
                        </ul>
                    </div>
                    <div class="product-media reveal">
                        <div class="gif-grid">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-d7490835-804b-41ee-931e-8eb773c17156.gif"
                                alt="Pan/Tilt Suite Demo 1" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-2d07796d-12fc-4500-bf1c-9f728fad3707.gif"
                                alt="Pan/Tilt Suite Demo 2" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-77b974be-a090-401a-930d-453e820293cc.gif"
                                alt="Pan/Tilt Suite Demo 3" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-41e5f527-9768-4414-bcbc-2e7f3d2c600a.gif"
                                alt="Pan/Tilt Suite Demo 4" loading="lazy">
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>