---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacts | 4x10.dev">
    <main>
        <section id="contacts" class="contacts-section reveal">
            <div class="container">
                <div class="contacts-info">
                    <p>Get in touch with us for collaborations and inquiries.</p>
                    <div class="contact-item" style="margin-bottom: 0.8rem; font-size: 1.1rem; color: var(--gray-color);">
                        Email <a href="mailto:hello@4x10.dev" style="color: #fff; text-decoration: none; font-weight: 700;">hello@4x10.dev</a>
                    </div>
                    <div class="contact-item" style="margin-bottom: 0.8rem; font-size: 1.1rem; color: var(--gray-color);">
                        Instagram <a href="https://instagram.com/4x10.dev" target="_blank" rel="noopener noreferrer" style="color: #fff; text-decoration: none; font-weight: 700;">@4x10.dev</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>