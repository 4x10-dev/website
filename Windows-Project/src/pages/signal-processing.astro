---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
<section id="signal-processing" class="product-section">
            <div class="container">
                <div class="product-grid inverse">
                    <div class="product-info reveal">
                        <h2>Signal Processing Engine</h2>
                        <h3>Realtime Control Core</h3>
                        <p class="description">A high-performance control core that rapidly processes complex bitmap
                            effects across large lighting arrays: delivering speed, flexibility, and new creative
                            possibilities for massive matrix setups.</p>
                        <ul class="feature-list">
                            <li>Fast creation of lighting effects using bitmaps as intuitive input</li>
                            <li>Bitmap mapping drives any fixture parameter</li>
                            <li>Position control using bitmap or vector attraction fields for fluid motion</li>
                            <li>Create and edit effects through natural prompts</li>
                            <li>Seamless alignment of lighting and video content</li>
                            <li>Built-in profiles with quick import and patching</li>
                        </ul>
                    </div>
                    <div class="product-media reveal">
                        <div class="gif-grid">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-28e0c9f7-d1ad-4d73-a05c-03e1dc50f812.gif"
                                alt="Signal Processing Engine Demo 1" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-95d195cc-3848-440b-9d0e-bad0255d9f07.gif"
                                alt="Signal Processing Engine Demo 2" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-402f1477-8bdd-4060-b3c3-82751b114a59.gif"
                                alt="Signal Processing Engine Demo 3" loading="lazy">
                            <img src="https://c-p.rmcdn1.net/64d10d2872c036003d9c3da8/5991296/Image-19f482e0-1696-4a96-9fb0-369b7df0bc3d.gif"
                                alt="Signal Processing Engine Demo 4" loading="lazy">
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>